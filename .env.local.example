# Copy this file to .env.local and fill in the values from your Supabase project.
# Find them at: Project Settings → Data API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Pick ONE of the following (either format is accepted):
# Newer "publishable" key (recommended): starts with sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Legacy "anon" JWT key (still works): long base64-encoded JWT starting with eyJ...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
